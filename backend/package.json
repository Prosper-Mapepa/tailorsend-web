{
  "name": "tailorsend-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run generate && tsc --noEmit",
    "generate": "node scripts/prepare-prisma.mjs && prisma generate --schema prisma/schema.prisma",
    "postinstall": "npm run generate",
    "start": "tsx src/index.ts",
    "test": "tsx src/test-auth.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.5",
    "typescript": "^5"
  }
}
