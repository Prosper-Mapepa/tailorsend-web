{
  "name": "jobs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "docs:sync": "rm -rf public/docs && mkdir -p public/docs/files && cp -R docs/investor/html/. public/docs/ && cp docs/investor/*.md docs/investor/*.csv public/docs/files/ && date +%s > public/docs/__reload.txt",
    "docs:watch": "node scripts/watch-investor-docs.mjs",
    "prebuild": "npm run docs:sync",
    "dev": "npm run docs:sync && npm run db:migrate && prisma generate && sh -c 'node scripts/watch-investor-docs.mjs & watcher=$!; trap \"kill $watcher 2>/dev/null\" EXIT INT TERM; next dev'",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "start:railway": "bash scripts/railway-start.sh",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "browser:install": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright install chromium",
    "backend:install": "npm install --prefix backend",
    "backend:dev": "npm run dev --prefix backend",
    "backend:build": "npm run build --prefix backend",
    "backend:test": "npm run test --prefix backend",
    "test:usage": "tsx src/lib/billing/usage.test.ts",
    "test:billing": "tsx --env-file=.env src/lib/billing/usage-integration.test.ts",
    "test:resume-import": "tsx src/lib/resume-import.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "openai": "^6.45.0",
    "pg": "^8.16.0",
    "playwright": "^1.61.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
